{
  "name": "memran/php-testify",
  "description": "Expressive PHP testing on top of PHPUnit with expect() assertions, describe()/it() specs, and watch mode.",
  "keywords": [
    "phpunit",
    "php",
    "test",
    "vitest",
    "jest",
    "watch",
    "bdd",
    "expect",
    "tdd",
    "testing"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Mohammad Emran",
      "email": "memran.dhk@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "phpunit/phpunit": "^11.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.76",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "Testify\\": "src/"
    },
    "files": [
      "src/functions.php"
    ]
  },
  "bin": [
    "bin/testify"
  ],
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit --configuration phpunit.xml.dist",
    "test:coverage": "vendor/bin/phpunit --configuration phpunit.xml.dist --coverage-text",
    "test:package": "php bin/testify --no-colors",
    "analyse": "vendor/bin/phpstan analyse --configuration=phpstan.neon.dist --no-progress --debug --memory-limit=512M",
    "lint": "vendor/bin/php-cs-fixer fix --dry-run --diff --verbose --sequential",
    "fix": "vendor/bin/php-cs-fixer fix --verbose --sequential",
    "ci": [
      "@lint",
      "@analyse",
      "@test",
      "@test:package"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
